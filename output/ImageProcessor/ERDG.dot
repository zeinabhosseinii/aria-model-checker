  "p1.processImage -> p1.processImage" -> "p1.processImage";
  "p1.processImage -> collector.storeResult" [shape=diamond, style=filled, fillcolor=yellow];
  "p1.processImage" -> "p1.processImage -> collector.storeResult";
  "p1.processImage -> collector.storeResult" -> "collector";
  "p1.processImage -> collector.storeResult" -> "collector.storeResult";
  "p2.ImageProcessor -> p2.processImage" [shape=diamond, style=filled, fillcolor=yellow];
