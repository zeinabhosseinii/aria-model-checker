  "p5.phase" [shape=box, style=filled, fillcolor="#FFA07A"];
  "p5.ImageProcessor" -> "p5.phase" [color=green, label="write"];
  "p5.phase" [shape=box, style=filled, fillcolor="#FFA07A"];
  "p5.processImage" -> "p5.phase" [color=green, label="write"];
  "collector.totalStored" -> "collector.storeResult" [color=blue, label="read"];
  "p1.phase" -> "p1.processImage" [color=blue, label="read"];
  "p2.phase" -> "p2.processImage" [color=blue, label="read"];
  "p3.phase" -> "p3.processImage" [color=blue, label="read"];
  "p4.phase" -> "p4.processImage" [color=blue, label="read"];
  "p5.phase" -> "p5.processImage" [color=blue, label="read"];
