  "p1.ImageProcessor -> p1.processImage" [shape=diamond, style=filled, fillcolor=yellow];
  "p1.ImageProcessor" -> "p1.ImageProcessor -> p1.processImage";
  "p1.ImageProcessor -> p1.processImage" -> "p1";
  "p1.ImageProcessor -> p1.processImage" -> "p1.processImage";
  "p1.processImage -> p1.processImage" [shape=diamond, style=filled, fillcolor=yellow];
