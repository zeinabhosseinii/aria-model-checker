graph RIG {
  rankdir=LR;
  "Tower" [shape=ellipse, style=filled, fillcolor=lightblue];
  "Alpha" [shape=ellipse, style=filled, fillcolor=lightblue];
  "Beta" [shape=ellipse, style=filled, fillcolor=lightblue];
  "Gamma" [shape=ellipse, style=filled, fillcolor=lightblue];
  "Delta" [shape=ellipse, style=filled, fillcolor=lightblue];
  "Alpha" -- "Beta";
  "Alpha" -- "Gamma";
  "Alpha" -- "Delta";
  "Beta" -- "Gamma";
  "Beta" -- "Delta";
  "Gamma" -- "Delta";
}
