digraph ERDG {
  rankdir=TB;
  "a" [shape=box, style=filled, fillcolor=lightblue, label="a\n(Agent)"];
  "ts" [shape=box, style=filled, fillcolor=lightblue, label="ts\n(TicketService)"];
  "c1" [shape=box, style=filled, fillcolor=lightblue, label="c1\n(Customer)"];
  "c2" [shape=box, style=filled, fillcolor=lightblue, label="c2\n(Customer)"];
  "c3" [shape=box, style=filled, fillcolor=lightblue, label="c3\n(Customer)"];
  "a.Agent" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "a" -> "a.Agent";
  "a.requestTicket" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "a" -> "a.requestTicket";
  "a.ticketIssued" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "a" -> "a.ticketIssued";
  "ts.TicketService" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "ts" -> "ts.TicketService";
  "ts.requestTicket" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "ts" -> "ts.requestTicket";
  "c1.Customer" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "c1" -> "c1.Customer";
  "c1.try" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "c1" -> "c1.try";
  "c1.ticketIssued" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "c1" -> "c1.ticketIssued";
  "c2.Customer" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "c2" -> "c2.Customer";
  "c2.try" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "c2" -> "c2.try";
  "c2.ticketIssued" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "c2" -> "c2.ticketIssued";
  "c3.Customer" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "c3" -> "c3.Customer";
  "c3.try" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "c3" -> "c3.try";
  "c3.ticketIssued" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "c3" -> "c3.ticketIssued";
  "a.requestTicket -> ts.requestTicket" [shape=diamond, style=filled, fillcolor=yellow];
  "a.requestTicket" -> "a.requestTicket -> ts.requestTicket";
  "a.requestTicket -> ts.requestTicket" -> "ts";
  "a.requestTicket -> ts.requestTicket" -> "ts.requestTicket";
  "ts.requestTicket -> a.ticketIssued" [shape=diamond, style=filled, fillcolor=yellow];
  "ts.requestTicket" -> "ts.requestTicket -> a.ticketIssued";
  "ts.requestTicket -> a.ticketIssued" -> "a";
  "ts.requestTicket -> a.ticketIssued" -> "a.ticketIssued";
  "c1.Customer -> c1.try" [shape=diamond, style=filled, fillcolor=yellow];
  "c1.Customer" -> "c1.Customer -> c1.try";
  "c1.Customer -> c1.try" -> "c1";
  "c1.Customer -> c1.try" -> "c1.try";
  "c1.try -> a.requestTicket" [shape=diamond, style=filled, fillcolor=yellow];
  "c1.try" -> "c1.try -> a.requestTicket";
  "c1.try -> a.requestTicket" -> "a";
  "c1.try -> a.requestTicket" -> "a.requestTicket";
  "c2.Customer -> c2.try" [shape=diamond, style=filled, fillcolor=yellow];
  "c2.Customer" -> "c2.Customer -> c2.try";
  "c2.Customer -> c2.try" -> "c2";
  "c2.Customer -> c2.try" -> "c2.try";
  "c2.try -> a.requestTicket" [shape=diamond, style=filled, fillcolor=yellow];
  "c2.try" -> "c2.try -> a.requestTicket";
  "c2.try -> a.requestTicket" -> "a";
  "c2.try -> a.requestTicket" -> "a.requestTicket";
  "c3.Customer -> c3.try" [shape=diamond, style=filled, fillcolor=yellow];
  "c3.Customer" -> "c3.Customer -> c3.try";
  "c3.Customer -> c3.try" -> "c3";
  "c3.Customer -> c3.try" -> "c3.try";
  "c3.try -> a.requestTicket" [shape=diamond, style=filled, fillcolor=yellow];
  "c3.try" -> "c3.try -> a.requestTicket";
  "c3.try -> a.requestTicket" -> "a";
  "c3.try -> a.requestTicket" -> "a.requestTicket";
  "a.shared" [shape=box, style=filled, fillcolor="#FFA07A"];
  "a.Agent" -> "a.shared" [color=green, label="write"];
  "a.shared" [shape=box, style=filled, fillcolor="#FFA07A"];
  "a.requestTicket" -> "a.shared" [color=green, label="write"];
  "c1.sent" [shape=box, style=filled, fillcolor="#FFA07A"];
  "c1.Customer" -> "c1.sent" [color=green, label="write"];
  "c1.id" [shape=box, style=filled, fillcolor="#FFA07A"];
  "c1.Customer" -> "c1.id" [color=green, label="write"];
  "c1.sent" [shape=box, style=filled, fillcolor="#FFA07A"];
  "c1.ticketIssued" -> "c1.sent" [color=green, label="write"];
  "c2.sent" [shape=box, style=filled, fillcolor="#FFA07A"];
  "c2.Customer" -> "c2.sent" [color=green, label="write"];
  "c2.id" [shape=box, style=filled, fillcolor="#FFA07A"];
  "c2.Customer" -> "c2.id" [color=green, label="write"];
  "c2.sent" [shape=box, style=filled, fillcolor="#FFA07A"];
  "c2.ticketIssued" -> "c2.sent" [color=green, label="write"];
  "c3.sent" [shape=box, style=filled, fillcolor="#FFA07A"];
  "c3.Customer" -> "c3.sent" [color=green, label="write"];
  "c3.id" [shape=box, style=filled, fillcolor="#FFA07A"];
  "c3.Customer" -> "c3.id" [color=green, label="write"];
  "c3.sent" [shape=box, style=filled, fillcolor="#FFA07A"];
  "c3.ticketIssued" -> "c3.sent" [color=green, label="write"];
  "a.shared" -> "a.requestTicket" [color=blue, label="read"];
