graph RIG {
  rankdir=LR;
  "rm" [shape=ellipse, style=filled, fillcolor=lightblue];
  "am1" [shape=ellipse, style=filled, fillcolor=lightblue];
  "am2" [shape=ellipse, style=filled, fillcolor=lightblue];
  "am3" [shape=ellipse, style=filled, fillcolor=lightblue];
  "am1" -- "am2";
  "am1" -- "am3";
  "am2" -- "am3";
}
