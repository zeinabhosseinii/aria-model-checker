digraph ERDG {
  rankdir=TB;
  "Endpoint" [shape=box, style=filled, fillcolor=lightblue, label="Endpoint\n(EndpointProcessor)"];
  "Stage1" [shape=box, style=filled, fillcolor=lightblue, label="Stage1\n(StageProcessor)"];
  "Stage2" [shape=box, style=filled, fillcolor=lightblue, label="Stage2\n(StageProcessor)"];
  "Handler1" [shape=box, style=filled, fillcolor=lightblue, label="Handler1\n(InputHandler)"];
  "Handler2" [shape=box, style=filled, fillcolor=lightblue, label="Handler2\n(InputHandler)"];
  "Orchestrator" [shape=box, style=filled, fillcolor=lightblue, label="Orchestrator\n(PipelineOrchestrator)"];
  "Endpoint.EndpointProcessor" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Endpoint" -> "Endpoint.EndpointProcessor";
  "Endpoint.HandleSecondary" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Endpoint" -> "Endpoint.HandleSecondary";
  "Endpoint.HandlePrimary" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Endpoint" -> "Endpoint.HandlePrimary";
  "Stage1.HandlePrimary" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Stage1" -> "Stage1.HandlePrimary";
  "Stage1.HandleSecondary" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Stage1" -> "Stage1.HandleSecondary";
  "Stage2.HandlePrimary" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Stage2" -> "Stage2.HandlePrimary";
  "Stage2.HandleSecondary" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Stage2" -> "Stage2.HandleSecondary";
  "Handler1.Process" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Handler1" -> "Handler1.Process";
  "Handler1.Forward" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Handler1" -> "Handler1.Forward";
  "Handler2.Process" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Handler2" -> "Handler2.Process";
  "Handler2.Forward" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Handler2" -> "Handler2.Forward";
  "Orchestrator.PipelineOrchestrator" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Orchestrator" -> "Orchestrator.PipelineOrchestrator";
  "Orchestrator.StartPipeline" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Orchestrator" -> "Orchestrator.StartPipeline";
  "Endpoint.HandleSecondary -> Handler1.Process" [shape=diamond, style=filled, fillcolor=yellow];
  "Endpoint.HandleSecondary" -> "Endpoint.HandleSecondary -> Handler1.Process";
  "Endpoint.HandleSecondary -> Handler1.Process" -> "Handler1";
  "Endpoint.HandleSecondary -> Handler1.Process" -> "Handler1.Process";
  "Endpoint.HandlePrimary -> Handler2.Forward" [shape=diamond, style=filled, fillcolor=yellow];
  "Endpoint.HandlePrimary" -> "Endpoint.HandlePrimary -> Handler2.Forward";
  "Endpoint.HandlePrimary -> Handler2.Forward" -> "Handler2";
  "Endpoint.HandlePrimary -> Handler2.Forward" -> "Handler2.Forward";
  "Stage1.HandlePrimary -> Endpoint.HandlePrimary" [shape=diamond, style=filled, fillcolor=yellow];
  "Stage1.HandlePrimary" -> "Stage1.HandlePrimary -> Endpoint.HandlePrimary";
  "Stage1.HandlePrimary -> Endpoint.HandlePrimary" -> "Endpoint";
  "Stage1.HandlePrimary -> Endpoint.HandlePrimary" -> "Endpoint.HandlePrimary";
  "Stage1.HandleSecondary -> Endpoint.HandleSecondary" [shape=diamond, style=filled, fillcolor=yellow];
  "Stage1.HandleSecondary" -> "Stage1.HandleSecondary -> Endpoint.HandleSecondary";
  "Stage1.HandleSecondary -> Endpoint.HandleSecondary" -> "Endpoint";
  "Stage1.HandleSecondary -> Endpoint.HandleSecondary" -> "Endpoint.HandleSecondary";
  "Stage2.HandlePrimary -> Endpoint.HandlePrimary" [shape=diamond, style=filled, fillcolor=yellow];
  "Stage2.HandlePrimary" -> "Stage2.HandlePrimary -> Endpoint.HandlePrimary";
  "Stage2.HandlePrimary -> Endpoint.HandlePrimary" -> "Endpoint";
  "Stage2.HandlePrimary -> Endpoint.HandlePrimary" -> "Endpoint.HandlePrimary";
  "Stage2.HandleSecondary -> Endpoint.HandleSecondary" [shape=diamond, style=filled, fillcolor=yellow];
  "Stage2.HandleSecondary" -> "Stage2.HandleSecondary -> Endpoint.HandleSecondary";
  "Stage2.HandleSecondary -> Endpoint.HandleSecondary" -> "Endpoint";
  "Stage2.HandleSecondary -> Endpoint.HandleSecondary" -> "Endpoint.HandleSecondary";
  "Handler1.Process -> Stage1.HandlePrimary" [shape=diamond, style=filled, fillcolor=yellow];
  "Handler1.Process" -> "Handler1.Process -> Stage1.HandlePrimary";
  "Handler1.Process -> Stage1.HandlePrimary" -> "Stage1";
  "Handler1.Process -> Stage1.HandlePrimary" -> "Stage1.HandlePrimary";
  "Handler1.Forward -> Stage1.HandleSecondary" [shape=diamond, style=filled, fillcolor=yellow];
  "Handler1.Forward" -> "Handler1.Forward -> Stage1.HandleSecondary";
  "Handler1.Forward -> Stage1.HandleSecondary" -> "Stage1";
  "Handler1.Forward -> Stage1.HandleSecondary" -> "Stage1.HandleSecondary";
  "Handler2.Process -> Stage2.HandlePrimary" [shape=diamond, style=filled, fillcolor=yellow];
  "Handler2.Process" -> "Handler2.Process -> Stage2.HandlePrimary";
  "Handler2.Process -> Stage2.HandlePrimary" -> "Stage2";
  "Handler2.Process -> Stage2.HandlePrimary" -> "Stage2.HandlePrimary";
  "Handler2.Forward -> Stage2.HandleSecondary" [shape=diamond, style=filled, fillcolor=yellow];
  "Handler2.Forward" -> "Handler2.Forward -> Stage2.HandleSecondary";
  "Handler2.Forward -> Stage2.HandleSecondary" -> "Stage2";
  "Handler2.Forward -> Stage2.HandleSecondary" -> "Stage2.HandleSecondary";
  "Orchestrator.PipelineOrchestrator -> Orchestrator.StartPipeline" [shape=diamond, style=filled, fillcolor=yellow];
  "Orchestrator.PipelineOrchestrator" -> "Orchestrator.PipelineOrchestrator -> Orchestrator.StartPipeline";
  "Orchestrator.PipelineOrchestrator -> Orchestrator.StartPipeline" -> "Orchestrator";
  "Orchestrator.PipelineOrchestrator -> Orchestrator.StartPipeline" -> "Orchestrator.StartPipeline";
  "Orchestrator.StartPipeline -> Handler1.Process" [shape=diamond, style=filled, fillcolor=yellow];
  "Orchestrator.StartPipeline" -> "Orchestrator.StartPipeline -> Handler1.Process";
  "Orchestrator.StartPipeline -> Handler1.Process" -> "Handler1";
  "Orchestrator.StartPipeline -> Handler1.Process" -> "Handler1.Process";
  "Orchestrator.StartPipeline -> Handler2.Forward" [shape=diamond, style=filled, fillcolor=yellow];
  "Orchestrator.StartPipeline" -> "Orchestrator.StartPipeline -> Handler2.Forward";
  "Orchestrator.StartPipeline -> Handler2.Forward" -> "Handler2";
  "Orchestrator.StartPipeline -> Handler2.Forward" -> "Handler2.Forward";
  "Endpoint.State" [shape=box, style=filled, fillcolor="#FFA07A"];
  "Endpoint.EndpointProcessor" -> "Endpoint.State" [color=green, label="write"];
  "Endpoint.State" [shape=box, style=filled, fillcolor="#FFA07A"];
  "Endpoint.HandleSecondary" -> "Endpoint.State" [color=green, label="write"];
  "Endpoint.State" [shape=box, style=filled, fillcolor="#FFA07A"];
  "Endpoint.HandlePrimary" -> "Endpoint.State" [color=green, label="write"];
  "Endpoint.State" -> "Endpoint.HandleSecondary" [color=blue, label="read"];
  "Endpoint.State" -> "Endpoint.HandlePrimary" [color=blue, label="read"];
}
