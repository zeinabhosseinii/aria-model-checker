digraph HRG {
  rankdir=TB;
  "G0" [shape=box, style=filled, fillcolor="#90EE90", label="Group 1\nEndpoint"];
  "G1" [shape=box, style=filled, fillcolor="#90EE90", label="Group 2\nStage1, Stage2"];
  "G2" [shape=box, style=filled, fillcolor="#90EE90", label="Group 3\nHandler1"];
  "G3" [shape=box, style=filled, fillcolor="#90EE90", label="Group 4\nHandler2"];
  "G4" [shape=box, style=filled, fillcolor="#90EE90", label="Group 5\nOrchestrator"];
  "G1" -> "G0";
  "G2" -> "G1";
  "G3" -> "G1";
}
