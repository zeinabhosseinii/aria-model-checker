digraph ERDG {
  rankdir=TB;
  "Hub" [shape=box, style=filled, fillcolor=lightblue, label="Hub\n(LoadBalancerHub)"];
  "PrimaryRelay" [shape=box, style=filled, fillcolor=lightblue, label="PrimaryRelay\n(PrimaryRelay)"];
  "SecondaryRelay" [shape=box, style=filled, fillcolor=lightblue, label="SecondaryRelay\n(SecondaryRelay)"];
  "PrimarySrc" [shape=box, style=filled, fillcolor=lightblue, label="PrimarySrc\n(PrimarySource)"];
  "SecondarySrc" [shape=box, style=filled, fillcolor=lightblue, label="SecondarySrc\n(SecondarySource)"];
  "Bootstrapper" [shape=box, style=filled, fillcolor=lightblue, label="Bootstrapper\n(SystemBootstrapper)"];
  "Hub.LoadBalancerHub" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Hub" -> "Hub.LoadBalancerHub";
  "Hub.ReceiveSecondary" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Hub" -> "Hub.ReceiveSecondary";
  "Hub.ReceivePrimary" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Hub" -> "Hub.ReceivePrimary";
  "PrimaryRelay.PrimaryRelay" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "PrimaryRelay" -> "PrimaryRelay.PrimaryRelay";
  "PrimaryRelay.Forward" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "PrimaryRelay" -> "PrimaryRelay.Forward";
  "SecondaryRelay.SecondaryRelay" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "SecondaryRelay" -> "SecondaryRelay.SecondaryRelay";
  "SecondaryRelay.Forward" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "SecondaryRelay" -> "SecondaryRelay.Forward";
  "PrimarySrc.PrimarySource" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "PrimarySrc" -> "PrimarySrc.PrimarySource";
  "PrimarySrc.Dispatch" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "PrimarySrc" -> "PrimarySrc.Dispatch";
  "SecondarySrc.SecondarySource" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "SecondarySrc" -> "SecondarySrc.SecondarySource";
  "SecondarySrc.Dispatch" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "SecondarySrc" -> "SecondarySrc.Dispatch";
  "Bootstrapper.SystemBootstrapper" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Bootstrapper" -> "Bootstrapper.SystemBootstrapper";
  "Bootstrapper.Initialize" [shape=ellipse, style=filled, fillcolor="#90EE90"];
  "Bootstrapper" -> "Bootstrapper.Initialize";
  "Hub.ReceiveSecondary -> PrimarySrc.Dispatch" [shape=diamond, style=filled, fillcolor=yellow];
  "Hub.ReceiveSecondary" -> "Hub.ReceiveSecondary -> PrimarySrc.Dispatch";
  "Hub.ReceiveSecondary -> PrimarySrc.Dispatch" -> "PrimarySrc";
  "Hub.ReceiveSecondary -> PrimarySrc.Dispatch" -> "PrimarySrc.Dispatch";
  "Hub.ReceivePrimary -> SecondarySrc.Dispatch" [shape=diamond, style=filled, fillcolor=yellow];
  "Hub.ReceivePrimary" -> "Hub.ReceivePrimary -> SecondarySrc.Dispatch";
  "Hub.ReceivePrimary -> SecondarySrc.Dispatch" -> "SecondarySrc";
  "Hub.ReceivePrimary -> SecondarySrc.Dispatch" -> "SecondarySrc.Dispatch";
  "PrimaryRelay.Forward -> Hub.ReceivePrimary" [shape=diamond, style=filled, fillcolor=yellow];
  "PrimaryRelay.Forward" -> "PrimaryRelay.Forward -> Hub.ReceivePrimary";
  "PrimaryRelay.Forward -> Hub.ReceivePrimary" -> "Hub";
  "PrimaryRelay.Forward -> Hub.ReceivePrimary" -> "Hub.ReceivePrimary";
  "SecondaryRelay.Forward -> Hub.ReceiveSecondary" [shape=diamond, style=filled, fillcolor=yellow];
  "SecondaryRelay.Forward" -> "SecondaryRelay.Forward -> Hub.ReceiveSecondary";
  "SecondaryRelay.Forward -> Hub.ReceiveSecondary" -> "Hub";
  "SecondaryRelay.Forward -> Hub.ReceiveSecondary" -> "Hub.ReceiveSecondary";
  "PrimarySrc.Dispatch -> PrimaryRelay.Forward" [shape=diamond, style=filled, fillcolor=yellow];
  "PrimarySrc.Dispatch" -> "PrimarySrc.Dispatch -> PrimaryRelay.Forward";
  "PrimarySrc.Dispatch -> PrimaryRelay.Forward" -> "PrimaryRelay";
  "PrimarySrc.Dispatch -> PrimaryRelay.Forward" -> "PrimaryRelay.Forward";
  "SecondarySrc.Dispatch -> SecondaryRelay.Forward" [shape=diamond, style=filled, fillcolor=yellow];
  "SecondarySrc.Dispatch" -> "SecondarySrc.Dispatch -> SecondaryRelay.Forward";
  "SecondarySrc.Dispatch -> SecondaryRelay.Forward" -> "SecondaryRelay";
  "SecondarySrc.Dispatch -> SecondaryRelay.Forward" -> "SecondaryRelay.Forward";
  "Bootstrapper.SystemBootstrapper -> Bootstrapper.Initialize" [shape=diamond, style=filled, fillcolor=yellow];
  "Bootstrapper.SystemBootstrapper" -> "Bootstrapper.SystemBootstrapper -> Bootstrapper.Initialize";
  "Bootstrapper.SystemBootstrapper -> Bootstrapper.Initialize" -> "Bootstrapper";
  "Bootstrapper.SystemBootstrapper -> Bootstrapper.Initialize" -> "Bootstrapper.Initialize";
  "Bootstrapper.Initialize -> PrimarySrc.Dispatch" [shape=diamond, style=filled, fillcolor=yellow];
  "Bootstrapper.Initialize" -> "Bootstrapper.Initialize -> PrimarySrc.Dispatch";
  "Bootstrapper.Initialize -> PrimarySrc.Dispatch" -> "PrimarySrc";
  "Bootstrapper.Initialize -> PrimarySrc.Dispatch" -> "PrimarySrc.Dispatch";
  "Bootstrapper.Initialize -> SecondarySrc.Dispatch" [shape=diamond, style=filled, fillcolor=yellow];
  "Bootstrapper.Initialize" -> "Bootstrapper.Initialize -> SecondarySrc.Dispatch";
  "Bootstrapper.Initialize -> SecondarySrc.Dispatch" -> "SecondarySrc";
  "Bootstrapper.Initialize -> SecondarySrc.Dispatch" -> "SecondarySrc.Dispatch";
  "Hub.SecondaryLoad" [shape=box, style=filled, fillcolor="#FFA07A"];
  "Hub.LoadBalancerHub" -> "Hub.SecondaryLoad" [color=green, label="write"];
  "Hub.PrimaryLoad" [shape=box, style=filled, fillcolor="#FFA07A"];
  "Hub.LoadBalancerHub" -> "Hub.PrimaryLoad" [color=green, label="write"];
  "Hub.PrimaryLoad" [shape=box, style=filled, fillcolor="#FFA07A"];
  "Hub.ReceiveSecondary" -> "Hub.PrimaryLoad" [color=green, label="write"];
  "Hub.SecondaryLoad" [shape=box, style=filled, fillcolor="#FFA07A"];
  "Hub.ReceivePrimary" -> "Hub.SecondaryLoad" [color=green, label="write"];
  "PrimaryRelay.Round" [shape=box, style=filled, fillcolor="#FFA07A"];
  "PrimaryRelay.PrimaryRelay" -> "PrimaryRelay.Round" [color=green, label="write"];
  "PrimaryRelay.Round" [shape=box, style=filled, fillcolor="#FFA07A"];
  "PrimaryRelay.Forward" -> "PrimaryRelay.Round" [color=green, label="write"];
  "SecondaryRelay.Round" [shape=box, style=filled, fillcolor="#FFA07A"];
  "SecondaryRelay.SecondaryRelay" -> "SecondaryRelay.Round" [color=green, label="write"];
  "SecondaryRelay.Round" [shape=box, style=filled, fillcolor="#FFA07A"];
  "SecondaryRelay.Forward" -> "SecondaryRelay.Round" [color=green, label="write"];
  "PrimarySrc.Cycle" [shape=box, style=filled, fillcolor="#FFA07A"];
  "PrimarySrc.PrimarySource" -> "PrimarySrc.Cycle" [color=green, label="write"];
  "PrimarySrc.Cycle" [shape=box, style=filled, fillcolor="#FFA07A"];
  "PrimarySrc.Dispatch" -> "PrimarySrc.Cycle" [color=green, label="write"];
  "SecondarySrc.Cycle" [shape=box, style=filled, fillcolor="#FFA07A"];
  "SecondarySrc.SecondarySource" -> "SecondarySrc.Cycle" [color=green, label="write"];
  "SecondarySrc.Cycle" [shape=box, style=filled, fillcolor="#FFA07A"];
  "SecondarySrc.Dispatch" -> "SecondarySrc.Cycle" [color=green, label="write"];
  "Hub.PrimaryLoad" -> "Hub.ReceiveSecondary" [color=blue, label="read"];
  "Hub.SecondaryLoad" -> "Hub.ReceivePrimary" [color=blue, label="read"];
  "PrimaryRelay.Round" -> "PrimaryRelay.Forward" [color=blue, label="read"];
  "SecondaryRelay.Round" -> "SecondaryRelay.Forward" [color=blue, label="read"];
  "PrimarySrc.Cycle" -> "PrimarySrc.Dispatch" [color=blue, label="read"];
  "SecondarySrc.Cycle" -> "SecondarySrc.Dispatch" [color=blue, label="read"];
}
